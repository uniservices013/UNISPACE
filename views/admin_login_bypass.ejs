<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Access - UniSpace</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #0a0a0f;
            --indigo: #6366f1;
            --indigo-dark: #4f46e5;
            --indigo-pale: #eef2ff;
            --emerald: #10b981;
            --amber: #f59e0b;
            --red: #ef4444;
            --gray: #6b7280;
            --rule: rgba(10,10,15,0.1);
            --bg: #fafaf8;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--bg);
            color: var(--ink);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow-x: hidden;
        }

        /* ── Texture overlay ── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
            opacity: 0.4;
        }

        .bg-text {
            position: fixed;
            bottom: -2rem;
            right: -1rem;
            font-family: 'Space Grotesk', sans-serif;
            font-size: clamp(6rem, 20vw, 18rem);
            font-weight: 700;
            color: rgba(99, 102, 241, 0.04);
            letter-spacing: -0.05em;
            pointer-events: none;
            z-index: 0;
            line-height: 1;
            user-select: none;
        }

        /* ── Main ── */
        .main {
            flex: 1;
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem 2rem;
        }

        .content {
            max-width: 720px;
            width: 100%;
            animation: reveal 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        @keyframes reveal {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Issue line ── */
        .issue-line {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 0.75rem;
        }

        .issue-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--indigo);
            background: var(--indigo-pale);
            border: 1px solid rgba(99,102,241,0.2);
            padding: 0.3rem 0.75rem;
            border-radius: 4px;
            white-space: nowrap;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            background: var(--amber);
            border-radius: 50%;
            animation: blink 1.8s ease-in-out infinite;
            flex-shrink: 0;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.3; }
        }

        .issue-rule {
            flex: 1;
            height: 1px;
            background: var(--rule);
        }

        /* ── Headline ── */
        .headline {
            font-size: clamp(2.2rem, 6vw, 4rem);
            font-weight: 700;
            line-height: 0.95;
            letter-spacing: -0.04em;
            color: var(--ink);
            margin-bottom: 0.5rem;
        }

        .headline em {
            font-style: normal;
            color: var(--indigo);
        }

        /* ── Deck ── */
        .deck {
            font-size: clamp(0.85rem, 1.5vw, 0.95rem);
            font-weight: 400;
            color: var(--gray);
            line-height: 1.55;
            margin-top: 0.75rem;
            margin-bottom: 1.25rem;
            max-width: 560px;
            border-left: 3px solid var(--indigo);
            padding-left: 1.25rem;
        }

        /* ── Rule ── */
        .h-rule {
            height: 1px;
            background: var(--rule);
            margin: 1rem 0;
            position: relative;
        }

        .h-rule::after {
            content: '◆';
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            font-size: 0.6rem;
            color: var(--indigo);
            background: var(--bg);
            padding: 0 0.5rem;
        }

        /* ── Notice ── */
        .notice {
            display: flex;
            align-items: flex-start;
            gap: 0.55rem;
            background: rgba(245,158,11,0.06);
            border: 1px solid rgba(245,158,11,0.22);
            border-radius: 6px;
            padding: 0.55rem 0.9rem;
            margin-bottom: 1.1rem;
            font-size: 0.78rem;
            color: #92400e;
            line-height: 1.5;
            max-width: 480px;
        }

        .notice-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--amber);
            flex-shrink: 0;
            margin-top: 0.28rem;
            animation: blink 2s ease-in-out infinite;
        }

        /* ── Form grid ── */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem 1.5rem;
            max-width: 560px;
            margin-bottom: 0;
        }

        .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
        .form-group.full { grid-column: 1 / -1; }

        label {
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--gray);
        }

        .input-wrap { position: relative; }

        .input-wrap i {
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 0.7rem;
            pointer-events: none;
            transition: color 0.2s;
        }

        input {
            width: 100%;
            padding: 0.6rem 0.75rem 0.6rem 2rem;
            background: #fff;
            border: 1.5px solid rgba(10,10,15,0.12);
            border-radius: 4px;
            color: var(--ink);
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.83rem;
            font-weight: 400;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        input::placeholder { color: #94a3b8; }

        input:focus {
            border-color: var(--indigo);
            box-shadow: 0 0 0 3px rgba(99,102,241,0.09);
        }

        .input-wrap:focus-within i { color: var(--indigo); }

        /* ── Bottom bar ── */
        .bottom-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            padding-top: 1.25rem;
            border-top: 2px solid var(--ink);
            max-width: 560px;
        }

        .bottom-notice {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.82rem;
            color: var(--gray);
        }

        .bottom-notice i { color: var(--emerald); }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.82rem;
            font-weight: 600;
            color: #fff;
            background: var(--indigo);
            border: none;
            padding: 0.55rem 1.25rem;
            border-radius: 4px;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
        }

        .btn-primary:hover {
            opacity: 0.88;
            transform: translateY(-1px);
        }

        .btn-primary i { font-size: 0.7rem; transition: transform 0.2s; }
        .btn-primary:hover i { transform: translateX(2px); }

        /* ── Error ── */
        .error {
            display: none;
            align-items: center;
            gap: 0.4rem;
            background: #fef2f2;
            border: 1px solid rgba(239,68,68,0.18);
            border-radius: 5px;
            padding: 0.55rem 0.75rem;
            margin-top: 0.875rem;
            font-size: 0.78rem;
            color: var(--red);
            font-weight: 500;
            max-width: 560px;
        }

        .error.visible { display: flex; }
        .error i { font-size: 0.7rem; flex-shrink: 0; }

        @media (max-width: 600px) {
            .form-grid { grid-template-columns: 1fr; }
            .form-group.full { grid-column: 1; }
            .bottom-bar { flex-direction: column; align-items: flex-start; }
            .main { padding: 1.5rem; }
        }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
        }
    </style>
</head>
<body>
    <div class="bg-text">ADM</div>

    <main class="main">
        <div class="content">

            <div class="issue-line">
                <div class="issue-tag">
                    <span class="status-dot"></span>
                    Restricted Access
                </div>
                <div class="issue-rule"></div>
            </div>

            <h1 class="headline">Administrator<br><em>login.</em></h1>

            <p class="deck">Restricted — Maintenance Mode Active. Authentication is required to proceed to the admin panel.</p>

            <div class="h-rule"></div>

            <div class="notice">
                <span class="notice-dot"></span>
                <span>Public access is suspended. Your credentials and session are verified server-side.</span>
            </div>

            <form id="adminLoginForm" autocomplete="off">
                <div class="form-grid">
                    <div class="form-group full">
                        <label>Email Address</label>
                        <div class="input-wrap">
                            <i class="fas fa-envelope"></i>
                            <input type="email" id="email" placeholder="admin@example.com" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <div class="input-wrap">
                            <i class="fas fa-key"></i>
                            <input type="password" id="password" placeholder="••••••••" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Bypass Key</label>
                        <div class="input-wrap">
                            <i class="fas fa-shield-alt"></i>
                            <input type="password" id="bypassKey" placeholder="From .env config" required>
                        </div>
                    </div>
                </div>

                <div id="error" class="error">
                    <i class="fas fa-exclamation-circle"></i>
                    <span id="errorMsg"></span>
                </div>

                <div class="bottom-bar" style="margin-top: 1rem;">
                    <div class="bottom-notice">
                        <i class="fas fa-shield-alt"></i>
                        Session credentials are verified server-side.
                    </div>
                    <button type="submit" class="btn-primary">
                        Proceed to Admin Panel
                        <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </form>

        </div>
    </main>

    <script>
        document.getElementById('adminLoginForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const bypassKey = document.getElementById('bypassKey').value;
            const errorEl = document.getElementById('error');
            const errorMsg = document.getElementById('errorMsg');

            errorEl.classList.remove('visible');

            try {
                const response = await fetch('/admin_login_bypass', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password, bypassKey })
                });

                const data = await response.json();

                if (data.success) {
                    window.location.href = data.redirect;
                } else {
                    errorMsg.textContent = data.message;
                    errorEl.classList.add('visible');
                }
            } catch (error) {
                errorMsg.textContent = 'Login failed. Please try again.';
                errorEl.classList.add('visible');
            }
        });
    </script>
</body>
</html>