<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error — Something Went Wrong | UniSpace</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #0a0a0f;
            --indigo: #6366f1;
            --indigo-pale: #eef2ff;
            --emerald: #10b981;
            --red: #ef4444;
            --red-pale: #fef2f2;
            --red-dark: #b91c1c;
            --gray: #6b7280;
            --rule: rgba(10,10,15,0.1);
            --bg: #fafaf8;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--bg);
            color: var(--ink);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow-x: hidden;
        }

        /* ── Texture overlay ── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
            opacity: 0.4;
        }

        /* ── Main content ── */
        .main {
            flex: 1;
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 5rem 2rem;
        }

        .content {
            max-width: 720px;
            width: 100%;
            animation: reveal 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
        }

        @keyframes reveal {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── Issue line ── */
        .issue-line {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .issue-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--red);
            background: var(--red-pale);
            border: 1px solid rgba(239,68,68,0.2);
            padding: 0.3rem 0.75rem;
            border-radius: 4px;
            white-space: nowrap;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            background: var(--red);
            border-radius: 50%;
            animation: blink 1.8s ease-in-out infinite;
            flex-shrink: 0;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.3; }
        }

        .issue-rule {
            flex: 1;
            height: 1px;
            background: var(--rule);
        }

        /* ── Headline ── */
        .headline {
            font-family: 'Space Grotesk', sans-serif;
            font-size: clamp(3rem, 8vw, 6.5rem);
            font-weight: 700;
            line-height: 0.95;
            letter-spacing: -0.04em;
            color: var(--ink);
            margin-bottom: 0.5rem;
        }

        .headline em {
            font-style: normal;
            color: var(--indigo);
        }

        /* ── Deck line ── */
        .deck {
            font-size: clamp(1rem, 2vw, 1.2rem);
            font-weight: 400;
            color: var(--gray);
            line-height: 1.6;
            margin-bottom: 1.5rem;
            margin-top: 1.25rem;
            max-width: 560px;
            border-left: 3px solid var(--red);
            padding-left: 1.25rem;
        }

        /* ── Message box ── */
        .message-box {
            display: flex;
            align-items: flex-start;
            gap: 0.65rem;
            background: var(--red-pale);
            border: 1px solid rgba(239,68,68,0.2);
            border-radius: 6px;
            padding: 0.85rem 1rem;
            margin-bottom: 2rem;
            max-width: 560px;
            font-size: 0.82rem;
            font-weight: 500;
            color: var(--red-dark);
            line-height: 1.5;
        }

        .message-box i {
            flex-shrink: 0;
            margin-top: 2px;
            font-size: 0.75rem;
            color: var(--red);
        }

        /* ── Rule ── */
        .h-rule {
            height: 1px;
            background: var(--rule);
            margin: 2rem 0;
            position: relative;
        }

        .h-rule::after {
            content: '◆';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 0.6rem;
            color: var(--indigo);
            background: var(--bg);
            padding: 0 0.5rem;
        }

        /* ── Three columns ── */
        .columns {
            display: grid;
            grid-template-columns: 1fr 1px 1fr 1px 1fr;
            gap: 0;
            margin-bottom: 2rem;
        }

        .col-divider {
            background: var(--rule);
        }

        .col {
            padding: 0 1.5rem;
        }

        .col:first-child { padding-left: 0; }
        .col:last-child  { padding-right: 0; }

        .col-label {
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--gray);
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .col-label i { color: var(--emerald); font-size: 0.6rem; }

        .col-value {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--ink);
            line-height: 1.2;
            letter-spacing: -0.02em;
        }

        .col-sub {
            font-size: 0.8rem;
            font-weight: 400;
            color: var(--gray);
            margin-top: 0.25rem;
        }

        /* ── Bottom bar ── */
        .bottom-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            padding-top: 1.25rem;
            border-top: 2px solid var(--ink);
        }

        .bottom-notice {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.82rem;
            font-weight: 400;
            color: var(--gray);
        }

        .bottom-notice i { color: var(--emerald); }

        .bottom-actions {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.82rem;
            font-weight: 600;
            color: #fff;
            background: var(--indigo);
            border: none;
            padding: 0.5rem 1.1rem;
            border-radius: 4px;
            text-decoration: none;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.15s;
        }

        .btn-primary:hover {
            opacity: 0.88;
            transform: translateY(-1px);
        }

        .btn-secondary {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--indigo);
            background: transparent;
            border: none;
            padding: 0;
            text-decoration: none;
            cursor: pointer;
            border-bottom: 1px solid transparent;
            transition: border-color 0.2s;
        }

        .btn-secondary:hover {
            border-color: var(--indigo);
        }

        /* ── Large background text ── */
        .bg-text {
            position: fixed;
            bottom: -2rem;
            right: -1rem;
            font-family: 'Space Grotesk', sans-serif;
            font-size: clamp(6rem, 20vw, 18rem);
            font-weight: 700;
            color: rgba(239, 68, 68, 0.04);
            letter-spacing: -0.05em;
            pointer-events: none;
            z-index: 0;
            line-height: 1;
            user-select: none;
        }

        @media (max-width: 600px) {
            .columns { grid-template-columns: 1fr; gap: 1.25rem; }
            .col-divider { display: none; }
            .col { padding: 0; }
            .bottom-bar { flex-direction: column; align-items: flex-start; }
            .bottom-actions { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
            .main { padding: 3.5rem 1.5rem; }
        }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after { animation-duration: 0.01ms !important; }
        }
    </style>
</head>
<body>
    <div class="bg-text">500</div>

    <main class="main">
        <div class="content">
            <div class="issue-line">
                <div class="issue-tag">
                    <span class="status-dot"></span>
                    System Error
                </div>
                <div class="issue-rule"></div>
            </div>

            <h1 class="headline">Something went<br><em>wrong.</em></h1>

            <p class="deck">We ran into an unexpected issue while processing your request.</p>

            <div class="message-box">
                <i class="fas fa-exclamation-triangle"></i>
                <%= message || 'An unexpected error occurred' %>
            </div>

            <div class="h-rule"></div>

            <div class="columns">
                <div class="col">
                    <div class="col-label"><i class="fas fa-circle"></i> Status</div>
                    <div class="col-value">Error</div>
                    <div class="col-sub">Unexpected failure</div>
                </div>
                <div class="col-divider"></div>
                <div class="col">
                    <div class="col-label"><i class="fas fa-circle"></i> Your Files</div>
                    <div class="col-value">100% Safe</div>
                    <div class="col-sub">Nothing has changed</div>
                </div>
                <div class="col-divider"></div>
                <div class="col">
                    <div class="col-label"><i class="fas fa-circle"></i> Resolution</div>
                    <div class="col-value">Try Again</div>
                    <div class="col-sub">Usually self-resolving</div>
                </div>
            </div>

            <div class="bottom-bar">
                <div class="bottom-notice">
                    <i class="fas fa-shield-alt"></i>
                    Your files and data remain safe &amp; private.
                </div>
                <div class="bottom-actions">
                    <a href="/" class="btn-primary">
                        Go to Home
                    </a>
                    <button class="btn-secondary" onclick="location.reload()">
                        Try Again →
                    </button>
                </div>
            </div>
        </div>
    </main>
</body>
</html>