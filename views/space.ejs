                    if (cat === 'image') { dec(imgTabBadge); dec(imgCountEl); if (storageData.images && storageData.images.length) storageData.images.shift(); }
                    if (cat === 'office') { dec(officeTabBadge); dec(officeCountEl); if (storageData.documents && storageData.documents.length) storageData.documents.shift(); }
