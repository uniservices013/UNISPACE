    <script id="storageDataJSON" type="application/json">
        <%- JSON.stringify({ pdfs: (user && user.pdfs) || [], images: (user && user.images) || [], documents: (user && user.documents) || [] }).replace(/</g, '\\u003c') %>
    </script>

    <script>
        let passwordVisible = false;
        let userPassword = '<%= user.pass %>';
        let currentDeleteType = '';
        let currentDeleteFilename = '';
        let currentDeleteName = '';
        let currentDeleteUserId = '<%= user._id %>';
        // Rename state
        let currentRenameType = '';
        let currentRenameFilename = '';
        let currentRenameName = '';
        let currentRenameCard = null;
        let currentRenameExt = '';

        let storageData;
        try {
            storageData = JSON.parse(document.getElementById('storageDataJSON').textContent);
            storageData.pdfs = (storageData.pdfs || []).map(p => ({ size: p.size || 0 }));
            storageData.images = (storageData.images || []).map(i => ({ size: i.size || 0 }));
            storageData.documents = (storageData.documents || []).map(d => ({ size: d.size || 0 }));
        } catch (e) { storageData = { pdfs: [], images: [], documents: [] }; }

        function getInitials(name) {
            if (!name) return 'U';
            return name.split(' ').map(w => w.charAt(0).toUpperCase()).join('').substring(0, 2);
        }

        function formatBytes(bytes) {
            if (!bytes || isNaN(bytes)) return '0 KB';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
        }

        function showStatus(element, message, type) {
            if (!element) return;
            element.textContent = message;
            element.className = 'status-message ' + type;
            element.style.display = 'block';
        }

        const _toastIcons = { success: 'fa-check-circle', error: 'fa-circle-exclamation', warning: 'fa-triangle-exclamation', info: 'fa-circle-info' };
        let _activeToast = null;
        function showToast(msg, type = 'success') {
            if (_activeToast) { _activeToast.classList.remove('show'); setTimeout(() => { if (_activeToast) { _activeToast.remove(); _activeToast = null; } }, 300); }
            const t = document.createElement('div');
            t.className = `toast ${type}`;
            t.innerHTML = `<i class="fas ${_toastIcons[type] || _toastIcons.success}"></i><span>${msg}</span>`;
            document.body.appendChild(t);
            _activeToast = t;
            requestAnimationFrame(() => requestAnimationFrame(() => t.classList.add('show')));
            setTimeout(() => { t.classList.remove('show'); setTimeout(() => { t.remove(); if (_activeToast === t) _activeToast = null; }, 300); }, 3000);
        }

        function setWelcomeBanner() {
            const now = new Date();
            const hour = now.getHours();
            const greeting = hour < 12 ? 'Good morning' : hour < 18 ? 'Good afternoon' : 'Good evening';
            const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
            const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
            const dateStr = `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()}`;
            const dayEl = document.getElementById('welcomeDay');
            const headingEl = document.getElementById('welcomeHeading');
            const userName = '<%= user.name.split(" ")[0] %>';
            if (dayEl) dayEl.textContent = dateStr;
            if (headingEl) {
                const em = document.createElement('em');
                em.textContent = userName + '.';
                headingEl.textContent = greeting + ', ';
                headingEl.appendChild(em);
            }
        }

        // Dark mode
        const darkModeToggle = document.getElementById('darkModeToggle');
        const html = document.documentElement;
        if (localStorage.getItem('theme') === 'dark') html.dataset.theme = 'dark';
        darkModeToggle.addEventListener('click', () => {
            const newTheme = html.dataset.theme === 'dark' ? 'light' : 'dark';
            html.dataset.theme = newTheme;
            localStorage.setItem('theme', newTheme);
        });

        // Sidebar collapse
        document.getElementById('collapseSidebar').addEventListener('click', () => {
            document.getElementById('layout').classList.toggle('sidebar-collapsed');
        });

        // Hamburger
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const sidebarEl = document.getElementById('sidebar');
        const sidebarOverlay = document.getElementById('sidebarOverlay');
        function openMobileSidebar() { sidebarEl.classList.add('mobile-open'); sidebarOverlay.classList.add('active'); document.body.style.overflow = 'hidden'; }
        function closeMobileSidebar() { sidebarEl.classList.remove('mobile-open'); sidebarOverlay.classList.remove('active'); document.body.style.overflow = ''; }
        hamburgerBtn.addEventListener('click', openMobileSidebar);
        sidebarOverlay.addEventListener('click', closeMobileSidebar);
        document.querySelectorAll('.nav-item, .sidebar-signout').forEach(el => {
            el.addEventListener('click', () => { if (window.innerWidth <= 768) closeMobileSidebar(); });
        });

        // Modal Manager
        const ModalManager = {
            open(id) {
                const m = document.getElementById(id);
                if (!m) return;
                if (id === 'unifiedUploadModal') {
                    const statusEl = document.getElementById('unifiedUploadStatus');
                    const selectedEl = document.getElementById('unifiedFileSelected');
                    const btn = document.getElementById('unifiedUploadBtn');
                    const inp = document.getElementById('unifiedFile');
                    if (statusEl) { statusEl.style.display = 'none'; statusEl.textContent = ''; }
                    if (selectedEl) selectedEl.style.display = 'none';
                    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-upload"></i> Upload'; }
                    if (inp) inp.value = '';
                    m.classList.add('show');
                    document.body.style.overflow = 'hidden';
                    const fileInp = document.getElementById('unifiedFile');
                    if (fileInp) setTimeout(() => fileInp.click(), 0);
                    return;
                }
                m.classList.add('show');
                document.body.style.overflow = 'hidden';
            },
            close(id) { const m = document.getElementById(id); if (m) { m.classList.remove('show'); document.body.style.overflow = ''; } },
            closeAll() { document.querySelectorAll('.modal.show').forEach(m => m.classList.remove('show')); document.body.style.overflow = ''; }
        };
        window.onclick = e => { if (e.target.classList.contains('modal')) ModalManager.closeAll(); };

        // Floating dropdown
        let activeMenuCard = null;
        let floatingDropdown = null;

        function createFloatingDropdown() {
            const el = document.createElement('div');
            el.className = 'file-card-dropdown';
            el.id = 'floatingFileMenu';
            document.body.appendChild(el);
            document.addEventListener('click', (e) => {
                if (!el.contains(e.target) && !e.target.closest('.file-card-menu-btn')) closeFloatingMenu();
            });
            return el;
        }

        function closeFloatingMenu() {
            if (floatingDropdown) floatingDropdown.classList.remove('open');
            activeMenuCard = null;
        }

        function toggleFileMenu(e, btn) {
            e.stopPropagation();
            if (!floatingDropdown) floatingDropdown = createFloatingDropdown();
            const card = btn.closest('.file-card');
            if (activeMenuCard === card && floatingDropdown.classList.contains('open')) { closeFloatingMenu(); return; }
            activeMenuCard = card;
            const fileType = card.getAttribute('data-filetype') || card.getAttribute('data-type');
            const filename = card.getAttribute('data-filename');
            const fileName = card.getAttribute('data-dlname') || filename;
            const viewHref = card.getAttribute('data-view') || '#';
            const dlHref = card.getAttribute('data-download') || '#';

            floatingDropdown.innerHTML = `
    <a href="${viewHref}" target="_blank" class="dropdown-item"><i class="fas fa-eye"></i> View</a>
    <a href="${dlHref}" download="${fileName}" class="dropdown-item"><i class="fas fa-download"></i> Download</a>
    <button class="dropdown-item" onclick="openRenameModal('${fileType}', '${filename}', '${fileName.replace(/'/g, "\\'")}')"><i class="fas fa-pencil-alt"></i> Rename</button>
    <div class="dropdown-divider"></div>
    <button class="dropdown-item danger" id="floatingDeleteBtn"><i class="fas fa-trash-alt"></i> Delete</button>
`;

            floatingDropdown.querySelector('#floatingDeleteBtn').addEventListener('click', (ev) => {
                ev.stopPropagation();
                closeFloatingMenu();
                openDeleteModal(fileType, filename, fileName);
            });

            const rect = btn.getBoundingClientRect();
            floatingDropdown.style.top = (rect.bottom + 4) + 'px';
            floatingDropdown.style.left = Math.max(4, rect.right - 156) + 'px';
            floatingDropdown.classList.add('open');

            requestAnimationFrame(() => {
                const dr = floatingDropdown.getBoundingClientRect();
                if (dr.bottom > window.innerHeight - 8) floatingDropdown.style.top = (rect.top - dr.height - 4) + 'px';
            });
        }

        // Rename functionality
        function openRenameModal(type, filename, name) {
            currentRenameType = type;
            currentRenameFilename = filename;
            currentRenameName = name;

            // Find the file card to get current display name
            const card = document.querySelector(`.file-card[data-filename="${filename}"]`);
            if (card) {
                currentRenameCard = card;
                const nameElement = card.querySelector('.file-card-name');
                if (nameElement) {
                    currentRenameName = nameElement.getAttribute('title') || nameElement.textContent;
                }
            }

            // Extract extension
            const extMatch = currentRenameName.match(/\.[^/.]+$/);
            currentRenameExt = extMatch ? extMatch[0] : '';

            // Display current name without extension in the modal
            const nameWithoutExt = currentRenameExt ? currentRenameName.slice(0, -currentRenameExt.length) : currentRenameName;

            document.getElementById('currentFileName').textContent = currentRenameName;
            document.getElementById('newFileName').value = nameWithoutExt;
            document.getElementById('renameFileStatus').style.display = 'none';

            // Close any open menu
            closeFloatingMenu();

            ModalManager.open('renameFileModal');

            // Focus and select the input
            setTimeout(() => {
                const input = document.getElementById('newFileName');
                input.focus();
                input.select();
            }, 300);
        }

        async function confirmRenameFile() {
            const newName = document.getElementById('newFileName').value.trim();
            const statusEl = document.getElementById('renameFileStatus');

            if (!newName) {
                showStatus(statusEl, 'Please enter a new name', 'error');
                return;
            }

            // Basic validation
            if (newName.length > 200) {
                showStatus(statusEl, 'Filename is too long', 'error');
                return;
            }

            if (/[<>:"/\\|?*]/.test(newName)) {
                showStatus(statusEl, 'Filename contains invalid characters', 'error');
                return;
            }

            const endpoints = {
                pdf: `/rename-pdf/${currentDeleteUserId}/${currentRenameFilename}`,
                image: `/rename-image/${currentDeleteUserId}/${currentRenameFilename}`,
                document: `/rename-document/${currentDeleteUserId}/${currentRenameFilename}`
            };

            const endpoint = endpoints[currentRenameType];
            if (!endpoint) return;

            try {
                showStatus(statusEl, 'Renaming...', 'info');

                const response = await fetch(endpoint, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ newName: newName })
                });

                const result = await response.json();

                if (result.success) {
                    showStatus(statusEl, 'File renamed successfully!', 'success');
                    showToast(`File renamed to "${result.newName}"`, 'success');

                    // Update all grid instances of this file
                    const grids = ['allFilesGrid', 'pdfFilesGrid', 'imageFilesGrid', 'officeFilesGrid'];
                    grids.forEach(gridId => {
                        const grid = document.getElementById(gridId);
                        if (!grid) return;

                        const cards = grid.querySelectorAll(`.file-card[data-filename="${currentRenameFilename}"]`);
                        cards.forEach(card => {
                            const nameElement = card.querySelector('.file-card-name');
                            const titleAttr = card.querySelector('.file-card-name');

                            if (nameElement) {
                                // Update display name (truncated)
                                let displayName = result.newName;
                                if (displayName.length > 18) {
                                    displayName = displayName.substring(0, 15) + '...';
                                }
                                nameElement.textContent = displayName;

                                // Update full name in title attribute
                                if (titleAttr) {
                                    titleAttr.setAttribute('title', result.newName);
                                }

                                // Update data-name attribute for search
                                card.setAttribute('data-name', result.newName.toLowerCase());

                                // Update the file extension badge if needed
                                const extSpan = card.querySelector('.file-card-ext');
                                if (extSpan) {
                                    const ext = result.newName.split('.').pop().toUpperCase();
                                    if (ext.length <= 4) {
                                        extSpan.textContent = ext;
                                    }
                                }
                            }
                        });
                    });

                    // Update storage data if needed (for counts, etc)
                    if (storageData) {
                        // Update the name in storageData if you're storing names
                        // This depends on your storageData structure
                    }

                    // Close modal after short delay
                    setTimeout(() => {
                        ModalManager.close('renameFileModal');
                    }, 1500);

                    // Refresh activities to show rename action
                    setTimeout(() => loadActivities(), 500);

                } else {
                    showStatus(statusEl, result.message || 'Failed to rename file', 'error');
                    showToast(result.message || 'Could not rename file.', 'error');
                }
            } catch (error) {
                console.error('Rename error:', error);
                showStatus(statusEl, 'An unexpected error occurred', 'error');
                showToast('An unexpected error occurred.', 'error');
            }
        }

        // Add keyboard support for rename modal
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && document.getElementById('renameFileModal')?.classList.contains('show')) {
                e.preventDefault();
                confirmRenameFile();
            }
        });

        // Tabs
        function setupTabs() {
            document.querySelectorAll('.nav-item').forEach(item => {
                item.addEventListener('click', () => {
                    const tabId = item.getAttribute('data-tab');
                    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
                    item.classList.add('active');
                    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                    const target = document.getElementById(tabId + 'Tab');
                    if (target) target.classList.add('active');
                    if (tabId === 'files') { requestAnimationFrame(() => { initializeFileTypeTabs(); populateFileTypeGrids(); const at = document.querySelector('.type-tab-btn.active'); if (at) at.click(); }); }
                    if (tabId === 'activity') { loadActivities(); }
                    if (tabId === 'dashboard') { calculateStorage(); }
                });
            });
        }

        function handleFileTypeClick(e) {
            const button = e.currentTarget;
            const fileType = button.getAttribute('data-type');
            document.querySelectorAll('.type-tab-btn').forEach(b => b.classList.remove('active'));
            button.classList.add('active');
            const grids = { all: 'allFilesGrid', pdf: 'pdfFilesGrid', images: 'imageFilesGrid', office: 'officeFilesGrid' };
