        // Search
        const searchInput = document.getElementById('searchInput');
        function performSearch() {
            if (!searchInput) return;
            const term = searchInput.value.toLowerCase().trim();
            const activeTab = document.querySelector('.type-tab-btn.active');
            const fileType = activeTab ? activeTab.getAttribute('data-type') : 'all';
            const gridMap = { all: 'allFilesGrid', pdf: 'pdfFilesGrid', images: 'imageFilesGrid', office: 'officeFilesGrid' };
            const grid = document.getElementById(gridMap[fileType]);
            if (!grid) return;
            const items = grid.querySelectorAll('.file-card');
            if (items.length === 0) return;
            let visibleCount = 0;
            items.forEach(item => {
                const name = item.getAttribute('data-name') || '';
                const matches = term === '' || name.includes(term);
                item.style.display = matches ? 'flex' : 'none';
                if (matches) visibleCount++;
            });
            const existing = grid.querySelector('.empty-state.search-empty');
            if (existing) existing.remove();
            if (visibleCount === 0 && items.length > 0) {
                const msg = document.createElement('div');
                msg.className = 'empty-state search-empty';
                msg.innerHTML = '<div class="empty-icon"><i class="fas fa-search"></i></div><p>No files match your search.</p>';
                grid.appendChild(msg);
            }
        }
        if (searchInput) searchInput.addEventListener('input', performSearch);

        // Storage
        function calculateStorage() {
            try {
                if (!storageData) return;
                const maxSize = 100 * 1024 * 1024;
                let pdfSize = 0, imgSize = 0, officeSize = 0;
                storageData.pdfs.forEach(p => { pdfSize += p.size || 0; });
                storageData.images.forEach(i => { imgSize += i.size || 0; });
                storageData.documents.forEach(d => { officeSize += d.size || 0; });
                const totalSize = pdfSize + imgSize + officeSize;
                const freeMB = (maxSize - totalSize) / (1024 * 1024);
                const percentage = Math.min((totalSize / maxSize) * 100, 100);
                const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
                set('storageUsedValue', percentage.toFixed(2));
                set('storagePercentage', percentage.toFixed(2) + '%');
                set('storageFreeMB', freeMB.toFixed(2) + ' MB free');
                const pdfPct = (pdfSize / maxSize) * 100;
                const imgPct = (imgSize / maxSize) * 100;
                const offPct = (officeSize / maxSize) * 100;
                const sd = document.getElementById('segDocs'); const si = document.getElementById('segImg'); const so = document.getElementById('segOther');
                if (sd) sd.style.width = pdfPct + '%';
                if (si) si.style.width = imgPct + '%';
                if (so) so.style.width = offPct + '%';
                const totalFiles = storageData.pdfs.length + storageData.images.length + storageData.documents.length;
                const pb = document.getElementById('pdfBar'); const ib = document.getElementById('imgBar'); const ob = document.getElementById('officeBar');
                if (totalFiles > 0) {
                    if (pb) pb.style.width = Math.round((storageData.pdfs.length / totalFiles) * 100) + '%';
                    if (ib) ib.style.width = Math.round((storageData.images.length / totalFiles) * 100) + '%';
                    if (ob) ob.style.width = Math.round((storageData.documents.length / totalFiles) * 100) + '%';
                } else {
                    if (pb) pb.style.width = '0%';
                    if (ib) ib.style.width = '0%';
                    if (ob) ob.style.width = '0%';
                }
                // Sync overview counts directly from storageData
                set('pdfCountCard', storageData.pdfs.length);
                set('imageCountCard', storageData.images.length);
                set('officeCountCard', storageData.documents.length);
                set('totalFilesCount', totalFiles);
                set('totalFilesCountSidebar', totalFiles);
            } catch (error) { console.error('Storage error:', error); }
        }

