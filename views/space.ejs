                const activities = await response.json();
                const recentBadge = document.getElementById('recentActivityBadge');
                if (recentBadge) {
                    if (activities.length > 0) {
                        recentBadge.textContent = Math.min(activities.length, 9) + (activities.length > 9 ? '+' : '');
                        recentBadge.style.display = 'inline-block';
                    } else { recentBadge.style.display = 'none'; }
                }
                const totalCount = document.getElementById('totalActivitiesCount');
                if (totalCount) totalCount.textContent = activities.length;
                renderActivityTimeline(activities);
                renderRecentActivities(activities.slice(0, 5));
            } catch (error) { console.error('Error loading activities:', error); showActivityError(); }
        }

        function renderActivityTimeline(activities) {
            const timeline = document.getElementById('activityTimeline');
            if (!timeline) return;
            if (!activities || activities.length === 0) {
                timeline.innerHTML = `<div style="text-align:center;padding:48px;color:var(--gray);"><i class="fas fa-history" style="font-size:32px;opacity:0.3;display:block;margin-bottom:12px;"></i><p style="font-size:14px;font-weight:600;color:var(--ink);">No activity yet</p><small>Your actions will appear here</small></div>`;
                return;
            }
            timeline.innerHTML = activities.map((activity, i) => {
                const icon = getActivityIcon(activity.type);
                const badgeClass = getActivityBadgeClass(activity.type);
                const timeAgo = getTimeAgo(new Date(activity.createdAt));
                const ip = activity.ip ? activity.ip.replace('::ffff:', '') : 'Unknown';
                return `
                    <div class="activity-item" style="animation-delay:${i * 0.04}s">
                        <div class="activity-icon ${icon.class}"><i class="${icon.icon}"></i></div>
                        <div class="activity-content">
                            <div>
                                <span class="activity-title">${activity.description}</span>
                                <span class="activity-badge ${badgeClass}">${getActivityTypeLabel(activity.type)}</span>
                            </div>
                            <div class="activity-meta">
                                <span><i class="far fa-clock" style="margin-right:3px;"></i>${timeAgo}</span>
                                ${activity.ip ? `<span><i class="fas fa-network-wired" style="margin-right:3px;"></i>${ip}</span>` : ''}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function renderRecentActivities(activities) {
            const list = document.getElementById('recentActivityList');
            if (!list) return;
            if (!activities || activities.length === 0) {
                list.innerHTML = `<div style="padding:12px 0;text-align:center;color:var(--gray);font-size:12px;"><i class="fas fa-history" style="display:block;font-size:18px;opacity:0.3;margin-bottom:4px;"></i>No recent activity</div>`;
                return;
            }
            list.innerHTML = activities.map(activity => {
                const dotClass = getActivityDotClass(activity.type);
                const timeAgo = getTimeAgo(new Date(activity.createdAt));
                const description = truncateText(activity.description, 40);
                return `
                    <div class="recent-activity-item">
                        <div class="recent-dot ${dotClass}"></div>
                        <span class="recent-text" title="${activity.description}">${description}</span>
                        <span class="recent-time">${timeAgo}</span>
                    </div>
                `;
            }).join('');
        }

        function getActivityIcon(type) {
            const icons = {
                'file_upload': { class: 'upload', icon: 'fas fa-cloud-upload-alt' },
                'file_delete': { class: 'delete', icon: 'fas fa-trash-alt' },
                'file_rename': { class: 'profile', icon: 'fas fa-pencil-alt' }, // Reuse profile style or create new
                'login': { class: 'login', icon: 'fas fa-sign-in-alt' },
                'profile_update': { class: 'profile', icon: 'fas fa-user-edit' },
                'password_change': { class: 'password', icon: 'fas fa-key' }
            };
            return icons[type] || { class: 'login', icon: 'fas fa-history' };
        }

        function getActivityBadgeClass(type) {
            return {
                'file_upload': 'upload',
                'file_delete': 'delete',
                'file_rename': 'profile'
            }[type] || '';
        }

        function getActivityDotClass(type) {
            return {
                'file_upload': 'upload',
                'file_delete': 'delete',
                'file_rename': 'profile',
                'login': 'login',
                'profile_update': 'profile',
                'password_change': 'password'
            }[type] || 'login';
        }

        function getActivityTypeLabel(type) {
            return {
                'file_upload': 'UPLOAD',
                'file_delete': 'DELETE',
                'file_rename': 'RENAME',
                'login': 'LOGIN',
                'profile_update': 'PROFILE',
                'password_change': 'SECURITY'
            }[type] || 'ACTIVITY';
        }

        function getTimeAgo(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            let interval = Math.floor(seconds / 31536000);
            if (interval >= 1) return interval + ' year' + (interval === 1 ? '' : 's') + ' ago';
            interval = Math.floor(seconds / 2592000);
            if (interval >= 1) return interval + ' month' + (interval === 1 ? '' : 's') + ' ago';
            interval = Math.floor(seconds / 86400);
            if (interval >= 1) return interval + ' day' + (interval === 1 ? '' : 's') + ' ago';
            interval = Math.floor(seconds / 3600);
            if (interval >= 1) return interval + ' hour' + (interval === 1 ? '' : 's') + ' ago';
            interval = Math.floor(seconds / 60);
            if (interval >= 1) return interval + ' minute' + (interval === 1 ? '' : 's') + ' ago';
            return 'just now';
        }

        function truncateText(text, maxLength) {
            if (!text) return '';
            return text.length > maxLength ? text.substring(0, maxLength) + '...' : text;
        }

        function showActivityError() {
            const timeline = document.getElementById('activityTimeline');
            if (timeline) timeline.innerHTML = `<div style="text-align:center;padding:40px;color:var(--danger);"><i class="fas fa-exclamation-triangle" style="font-size:24px;display:block;margin-bottom:8px;"></i>Failed to load activities</div>`;
            const recentList = document.getElementById('recentActivityList');
            if (recentList) recentList.innerHTML = `<div style="padding:12px;text-align:center;color:var(--danger);font-size:12px;"><i class="fas fa-exclamation-circle"></i> Error loading</div>`;
        }

        // Delete Account
        async function confirmDeleteAccount() {
            ModalManager.close('deleteModal');
            document.getElementById('deleteAnimation').classList.add('active');
            await new Promise(r => setTimeout(r, 2000));
            try {
                const r = await fetch('/delete-account', { method: 'DELETE', headers: { 'Content-Type': 'application/json' } });
                const result = await r.json();
                if (result.success) { sessionStorage.clear(); localStorage.clear(); window.location.href = result.redirect || '/'; }
                else { document.getElementById('deleteAnimation').classList.remove('active'); showToast('Could not delete account. Please try again.', 'error'); }
            } catch (e) { document.getElementById('deleteAnimation').classList.remove('active'); showToast('An unexpected error occurred.', 'error'); }
        }

        // Init
        window.addEventListener('load', function () {
            setWelcomeBanner();
            setupTabs();
            calculateStorage();
            const activeNav = document.querySelector('.nav-item.active');
            if (activeNav) { const tabId = activeNav.getAttribute('data-tab'); const t = document.getElementById(tabId + 'Tab'); if (t) t.classList.add('active'); }
            loadActivities();
            setTimeout(() => {
                const loader = document.getElementById('loader');
                if (loader) { loader.style.opacity = '0'; setTimeout(() => loader.style.display = 'none', 300); }
            }, 600);
        });
    </script>
</body>

</html>